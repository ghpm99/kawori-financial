{
    "extends": "./tsconfig.json",
    "include": [
        "next-env.d.ts",
        "src/**/*.d.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "src/**/__tests__/**/*.ts",
        "src/**/__tests__/**/*.tsx"
    ],
    "exclude": ["node_modules"]
}
